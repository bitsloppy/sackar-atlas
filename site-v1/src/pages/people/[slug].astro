---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';
import SectionCard from '../../components/SectionCard.astro';
import BadgeTag from '../../components/BadgeTag.astro';

export async function getStaticPaths() {
  const people = await getCollection('people');
  return people.map(entry => ({
    params: { slug: entry.id.replace(/\.md$/, '') },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const d = entry.data;

// Cross-reference related content
const allCases = await getCollection('cases', ({ data }) => data.published === true);
const allEvents = await getCollection('events');
const allLocations = await getCollection('locations');
const allPeople = await getCollection('people');

const relatedCases = (d.related_cases ?? [])
  .map(id => allCases.find(c => c.id.replace(/\.md$/, '') === id))
  .filter((x): x is NonNullable<typeof x> => x != null);

const relatedEvents = (d.related_events ?? [])
  .map(id => allEvents.find(e => e.id.replace(/\.md$/, '') === id))
  .filter((x): x is NonNullable<typeof x> => x != null);

const relatedLocations = (d.related_locations ?? [])
  .map(id => allLocations.find(l => l.id.replace(/\.md$/, '') === id))
  .filter((x): x is NonNullable<typeof x> => x != null);

const relatedPeople = (d.related_people ?? [])
  .map(id => allPeople.find(p => p.id.replace(/\.md$/, '') === id))
  .filter((x): x is NonNullable<typeof x> => x != null);

function roleLabel(role: string): string {
  const labels: Record<string, string> = {
    victim: 'Victim',
    activist: 'Activist',
    witness: 'Witness',
    'expert-witness': 'Expert witness',
    pathologist: 'Pathologist',
    coroner: 'Coroner',
    perpetrator: 'Perpetrator',
    police: 'Police',
    'police-officer': 'Police officer',
    legal: 'Legal',
    political: 'Political',
    community: 'Community',
    journalist: 'Journalist',
    other: 'Other',
  };
  return labels[role] ?? role;
}

function roleBadgeClass(role: string): string {
  const classes: Record<string, string> = {
    victim: 'badge-homicide',
    activist: 'badge-beat',
    witness: 'badge-open',
    'expert-witness': 'badge-open',
    pathologist: 'badge-open',
    coroner: 'badge-scoi-b',
    perpetrator: 'badge-probable',
    police: 'badge-scoi-a',
    'police-officer': 'badge-scoi-a',
    legal: 'badge-scoi-b',
    political: 'badge-possible',
    community: 'badge-beat',
    journalist: 'badge-venue',
    other: 'badge-excluded',
  };
  return classes[role] ?? 'badge-excluded';
}

function statusLabel(status: string | undefined): string {
  const labels: Record<string, string> = {
    'confirmed-homicide': 'Confirmed homicide',
    probable: 'Probable hate crime',
    possible: 'Possible hate crime',
    open: 'Open finding',
    undetermined: 'Undetermined',
    excluded: 'Excluded',
    missing: 'Missing person',
  };
  return labels[status ?? ''] ?? status ?? '—';
}

function statusBadgeClass(status: string | undefined): string {
  const classes: Record<string, string> = {
    'confirmed-homicide': 'badge-homicide',
    probable: 'badge-probable',
    possible: 'badge-possible',
    open: 'badge-open',
    undetermined: 'badge-open',
    excluded: 'badge-excluded',
    missing: 'badge-open',
  };
  return classes[status ?? ''] ?? 'badge-open';
}

// Display also_known_as — only show names with display: true (skip dead names etc.)
const displayedNames = d.also_known_as.filter(n => n.display !== false);
---

<Base
  title={d.name}
  description={`${roleLabel(d.role)}: ${d.name}. ${d.institutional_role ?? ''} — Sackar Atlas.`}
>
  <!-- ══ SECTION: Stub warning ═══════════════════════════════════════════════ -->
  <!-- Conditional: only shown when stub: true.                               -->
  {
    d.stub && (
      <wa-callout variant="warning" appearance="accent">
        <strong>Research stub:</strong> This person record is a placeholder. Key details may be
        incomplete or unverified.
      </wa-callout>
    )
  }

  <!-- ══ SECTION: Content warning ═════════════════════════════════════════════ -->
  <!-- Conditional: only shown when person is a victim (role=victim).         -->
  {
    d.content_warnings.includes('deceased-person') && (
      <wa-callout variant="danger" appearance="accent">
        <strong>Content warning:</strong> This record documents a deceased person and may contain
        details of violence.
      </wa-callout>
    )
  }

  <!-- ══ SECTION: Header ════════════════════════════════════════════════════ -->
  <!-- Name, role badge, dates.                                               -->
  <div class="detail-header">
    <h1>{d.name}</h1>

    {d.pronouns && (
      <p class="text-muted text-ui" style="font-size:0.85rem; margin-bottom:0.5rem">
        {d.pronouns}
      </p>
    )}

    {
      displayedNames.length > 0 && (
        <p class="text-muted text-ui" style="font-size:0.85rem; margin-bottom:0.5rem">
          Also known as:{' '}
          {displayedNames
            .map(n => n.name + (n.kind && n.kind !== 'alias' ? ` (${n.kind.replace(/-/g, ' ')})` : ''))
            .join(', ')}
        </p>
      )
    }

    <div class="detail-meta">
      {d.institutional_role && (
        <span>
          {d.institutional_role}
          {d.institution && `, ${d.institution}`}
        </span>
      )}
      {d.tenure_start && (
        <span>
          {d.tenure_start}
          {d.tenure_end ? `–${d.tenure_end}` : '–present'}
        </span>
      )}
      {d.living === false && !d.died_date && !d.death_year && <span>Deceased</span>}
    </div>

    <div class="detail-badges">
      <BadgeTag cls={roleBadgeClass(d.role)}>{roleLabel(d.role)}</BadgeTag>
      {d.stub && <BadgeTag cls="badge-stub">Research needed</BadgeTag>}
    </div>
  </div>

  <!-- ══ SECTION: Key facts grid ════════════════════════════════════════════ -->
  <!-- Role · Born/died · Affiliation · Tenure etc.                           -->
  <div class="fact-grid">
    {
      (d.born_date ?? d.birth_year) && (
        <div class="fact">
          <span class="fact-label">Born</span>
          <span class="fact-value">{d.born_date ?? d.birth_year}</span>
        </div>
      )
    }

    {
      (d.died_date ?? d.death_year) && (
        <div class="fact">
          <span class="fact-label">Died</span>
          <span class="fact-value">
            {d.died_date ?? d.death_year}
            {d.died_date_uncertain && ' (approx)'}
          </span>
        </div>
      )
    }

    {
      d.living === false && !d.died_date && !d.death_year && (
        <div class="fact">
          <span class="fact-label">Status</span>
          <span class="fact-value">Deceased</span>
        </div>
      )
    }

    {
      d.role === 'victim' && d.sexuality?.identity && d.sexuality.identity !== 'unknown' && (
        <div class="fact">
          <span class="fact-label">Sexuality</span>
          <span class="fact-value">
            {d.sexuality.identity}
            {d.sexuality.confidence && d.sexuality.confidence !== 'unknown' && (
              <span class="text-muted" style="font-size:0.85rem">
                {' '}
                ({d.sexuality.confidence})
              </span>
            )}
          </span>
        </div>
      )
    }

    {
      d.political_party && (
        <div class="fact">
          <span class="fact-label">Party</span>
          <span class="fact-value">{d.political_party}</span>
        </div>
      )
    }

    {
      d.government_level && (
        <div class="fact">
          <span class="fact-label">Level</span>
          <span class="fact-value">{d.government_level.replace(/-/g, ' ')}</span>
        </div>
      )
    }

    {
      d.wikipedia_url && (
        <div class="fact">
          <span class="fact-label">Wikipedia</span>
          <span class="fact-value">
            <a href={d.wikipedia_url}>Wikipedia</a>
          </span>
        </div>
      )
    }
  </div>

  <!-- ══ SECTION: Narrative body ════════════════════════════════════════════ -->
  <!-- Markdown prose from the data file.                                     -->
  <div class="narrative">
    <Content />
  </div>

  <wa-divider></wa-divider>

  <!-- ══ SECTION: Related info tabs ══════════════════════════════════════════ -->
  <p class="section-heading" style="margin-top:2rem">Related info</p>
  <wa-tab-group label="Related info">

    <wa-tab slot="nav" panel="people">People</wa-tab>
    <wa-tab slot="nav" panel="cases">Cases</wa-tab>
    <wa-tab slot="nav" panel="locations">Locations</wa-tab>
    <wa-tab slot="nav" panel="events">Events</wa-tab>

    <wa-tab-panel name="people">
      {relatedPeople.length > 0 ? (
        <div class="related-chips">
          {relatedPeople.map(p => {
            const slug = p.id.replace(/\.md$/, '');
            return (
              <a href={`/people/${slug}/`} class="related-chip">
                {p.data.name}
                <span class="chip-meta"> · {roleLabel(p.data.role)}</span>
              </a>
            );
          })}
        </div>
      ) : <p class="text-muted text-ui" style="font-size:0.88rem; margin:0">None recorded.</p>}
    </wa-tab-panel>

    <wa-tab-panel name="cases">
      {relatedCases.length > 0 ? (
        <div class="card-grid">
          {relatedCases.map(c => {
            const slug = c.id.replace(/\.md$/, '');
            const siteStatus = c.data.manner_findings?.site_status;
            return (
              <article class="card">
                <div class="card-badges">
                  {c.data.scoi_category && (
                    <BadgeTag cls={`badge-scoi-${c.data.scoi_category.toLowerCase()}`}>
                      SCOI Cat. {c.data.scoi_category}
                    </BadgeTag>
                  )}
                  {siteStatus && (
                    <BadgeTag cls={statusBadgeClass(siteStatus)}>{statusLabel(siteStatus)}</BadgeTag>
                  )}
                </div>
                <a href={`/cases/${slug}/`} class="card-name">{c.data.name}</a>
                <div class="card-meta">
                  {c.data.date_of_death_display ?? c.data.date_of_death ?? 'Date unknown'}
                </div>
              </article>
            );
          })}
        </div>
      ) : <p class="text-muted text-ui" style="font-size:0.88rem; margin:0">None recorded.</p>}
    </wa-tab-panel>

    <wa-tab-panel name="locations">
      {relatedLocations.length > 0 ? (
        <div class="related-chips">
          {relatedLocations.map(l => {
            const slug = l.id.replace(/\.md$/, '');
            return (
              <a href={`/locations/${slug}/`} class="related-chip">
                {l.data.name}
                {l.data.suburb && <span class="chip-meta"> · {l.data.suburb}</span>}
              </a>
            );
          })}
        </div>
      ) : <p class="text-muted text-ui" style="font-size:0.88rem; margin:0">None recorded.</p>}
    </wa-tab-panel>

    <wa-tab-panel name="events">
      {relatedEvents.length > 0 ? (
        <div class="related-chips">
          {relatedEvents.map(e => {
            const slug = e.id.replace(/\.md$/, '');
            return (
              <a href={`/events/${slug}/`} class="related-chip">
                {e.data.title}
                {(e.data.date_display ?? e.data.date) && (
                  <span class="chip-meta"> · {e.data.date_display ?? e.data.date}</span>
                )}
              </a>
            );
          })}
        </div>
      ) : <p class="text-muted text-ui" style="font-size:0.88rem; margin:0">None recorded.</p>}
    </wa-tab-panel>

  </wa-tab-group>

  <!-- ══ SECTION: Sources ══════════════════════════════════════════════════ -->
  <!-- Always shown.                                                          -->
  <SectionCard type="sources" heading="Sources" open={false}>

    {d.sources.press.length > 0 && (
      <div style="margin-top:0.5rem">
        <h4 style="margin-bottom:0.5rem">Press sources</h4>
        <ul class="text-ui" style="font-size:0.85rem; list-style:none; display:flex; flex-direction:column; gap:0.5rem">
          {d.sources.press.map(p => (
            <li>
              {p.author && <>{p.author} </>}
              {p.date && <>({p.date}) </>}
              '{p.title}',<em> {p.publication}</em>
              {p.page && <>, p. {p.page}</>}
              {p.trove_url && <> · <a href={p.trove_url}>Trove</a></>}
              {!p.trove_url && p.url && <> · <a href={p.url}>{p.url}</a></>}
            </li>
          ))}
        </ul>
      </div>
    )}

    {d.sources.hansard.length > 0 && (
      <div style="margin-top:1rem">
        <h4 style="margin-bottom:0.5rem">Hansard</h4>
        <ul class="text-ui" style="font-size:0.85rem; list-style:none; display:flex; flex-direction:column; gap:0.5rem">
          {d.sources.hansard.map(h => (
            <li>
              {h.chamber} ({h.date})
              {h.title && <> — <em>{h.title}</em></>}
              {h.volume && <>, vol. {h.volume}</>}
              {h.page && <>, p. {h.page}</>}
              {h.url && <> · <a href={h.url}>View</a></>}
            </li>
          ))}
        </ul>
      </div>
    )}

    {d.sources.reports.length > 0 && (
      <div style="margin-top:1rem">
        <h4 style="margin-bottom:0.5rem">Reports</h4>
        <ul class="text-ui" style="font-size:0.85rem; list-style:none; display:flex; flex-direction:column; gap:0.5rem">
          {d.sources.reports.map(r => (
            <li>
              {r.author && <>{r.author} </>}({r.year}) <em>{r.title}</em>, {r.organisation}
              {r.page && <>, p. {r.page}</>}
              {r.url && <> · <a href={r.url}>View</a></>}
            </li>
          ))}
        </ul>
      </div>
    )}

    {d.sources.archives.length > 0 && (
      <div style="margin-top:1rem">
        <h4 style="margin-bottom:0.5rem">Archival records</h4>
        <ul class="text-ui" style="font-size:0.85rem; list-style:none; display:flex; flex-direction:column; gap:0.5rem">
          {d.sources.archives.map(a => (
            <li>
              {a.institution.replace(/-/g, ' ')}
              {a.collection && <>, {a.collection}</>}
              {a.item_id && <>, item {a.item_id}</>}
              {a.description && <> — {a.description}</>}
            </li>
          ))}
        </ul>
      </div>
    )}

    {!d.sources.press.length && !d.sources.hansard.length && !d.sources.reports.length && !d.sources.archives.length && (
      <p class="text-muted text-ui" style="font-size:0.85rem">No sources listed yet.</p>
    )}

  </SectionCard>

  <!-- ══ SECTION: Back link ════════════════════════════════════════════════ -->
  <div style="margin-top:3rem; padding-top:1rem; border-top:1px solid var(--border)">
    <a href="/people/" class="text-ui" style="font-size:0.88rem">← All people</a>
  </div>
</Base>
