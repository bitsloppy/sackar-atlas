---
interface Props {
  title: string;
  description?: string;
}

import '../styles/global.css';
// Web Awesome — cascade layers (ordering) + design tokens only.
// Do NOT import webawesome.css (includes native.css which overrides our element styles).
import '@awesome.me/webawesome/dist/styles/layers.css';
import '@awesome.me/webawesome/dist/styles/themes/default.css';
import { DESIGN_TOKENS } from '../lib/tokens';

// Build :root { --key: value; ... } block from design tokens
const rootVars = Object.entries(DESIGN_TOKENS)
  .map(([k, v]) => `  --${k}: ${v};`)
  .join('\n');
const rootCss = `:root {\n${rootVars}\n}`;

const {
  title,
  description = 'A public record of LGBTIQ lives examined by the NSW Special Commission of Inquiry into LGBTIQ Hate Crimes (Sackar, 2023).',
} = Astro.props;
---

<!doctype html>
<html lang="en" class="wa-theme-default wa-palette-default wa-brand-blue">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&family=Special+Elite&display=swap" rel="stylesheet" />
    <title>{title === 'Home' ? 'Sackar Atlas' : `${title} — Sackar Atlas`}</title>
    <Fragment set:html={`<style>${rootCss}</style>`} />
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <header>
      <nav aria-label="Site navigation">
        <a href="/" class="site-name">Sackar Atlas</a>
        <ul>
          <li><a href="/cases/">Cases</a></li>
          <li><a href="/locations/">Locations</a></li>
          <li><a href="/events/">Events</a></li>
          <li><a href="/people/">People</a></li>
          <li><a href="/map/">Map</a></li>
        </ul>
      </nav>
    </header>

    <main id="main-content">
      <slot />
    </main>

    <footer>
      <div class="inner">
        <p>
          A research project by <a href="https://bitsloppy.com">Anna Roberts</a>.
          Data and code on <a href="https://github.com/bitsloppy/sackar-atlas">GitHub</a>.
          Data: <a href="https://creativecommons.org/licenses/by/4.0/">CC-BY 4.0</a>.
        </p>
        <p>
          Based on the <a href="https://www.nsw.gov.au/departments-and-agencies/cabinet-office/resources/special-commissions-of-inquiry/lgbtiq-hate-crimes">NSW Special Commission of Inquiry into LGBTIQ Hate Crimes</a> (Sackar J, 2023).
        </p>
        <p class="country">
          This project documents events across Gadigal, Bidjigal, Gayamaygal, and other Countries.
          We acknowledge the Traditional Custodians of Country throughout this work and pay our respects to Elders past, present, and emerging.
        </p>
      </div>
    </footer>
  </body>
  <!-- Web Awesome: register components used site-wide.
       Vite cherry-picks only what's imported — no dead code.
       NOTE: wa-icon needs a kit code or custom icon library to display
       icons. setBasePath points WA at the right asset location when set.
       Video does not exist in Web Awesome (use <video> or wa-animated-image).
  -->
  <script>
    // ── Only import components that are actually used on the site ──────
    // Unused imports add bundle weight for nothing — WA cherry-picks per file.

    // Used site-wide: callout (content warnings, stubs), divider, tabs, tag (badges)
    import '@awesome.me/webawesome/dist/components/callout/callout.js';
    import '@awesome.me/webawesome/dist/components/divider/divider.js';
    import '@awesome.me/webawesome/dist/components/tag/tag.js';
    import '@awesome.me/webawesome/dist/components/tab/tab.js';
    import '@awesome.me/webawesome/dist/components/tab-group/tab-group.js';
    import '@awesome.me/webawesome/dist/components/tab-panel/tab-panel.js';

    // Add new imports here as components are adopted.
    // Reference: https://webawesome.com/docs/components
  </script>
</html>
