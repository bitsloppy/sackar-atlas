---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const events = await getCollection('events');

// Sort chronologically by date ascending; undated go last
const sorted = [...events].sort((a, b) => {
  const da = a.data.date ?? '9999';
  const db = b.data.date ?? '9999';
  return da.localeCompare(db);
});

function eventTypeLabel(type: string): string {
  const labels: Record<string, string> = {
    activism: 'Activism',
    'legal-milestone': 'Legal milestone',
    cultural: 'Cultural',
    political: 'Political',
    community: 'Community',
    'police-action': 'Police action',
    memorial: 'Memorial',
    media: 'Media',
    inquiry: 'Inquiry',
    other: 'Other',
  };
  return labels[type] ?? type;
}

function eventTypeBadgeClass(type: string): string {
  const classes: Record<string, string> = {
    activism: 'badge badge-probable',
    'legal-milestone': 'badge badge-scoi-a',
    cultural: 'badge badge-venue',
    political: 'badge badge-open',
    community: 'badge badge-beat',
    'police-action': 'badge badge-homicide',
    memorial: 'badge badge-possible',
    media: 'badge badge-excluded',
    inquiry: 'badge badge-scoi-b',
    other: 'badge badge-excluded',
  };
  return classes[type] ?? 'badge badge-excluded';
}
---

<Base
  title="Events"
  description="Historical events in the Queer Heritage Sydney research project — activism, law reform, cultural moments, police actions, and memorials."
>
  <h1>Events</h1>
  <p class="text-muted text-ui" style="font-size:0.9rem; margin: 0.5rem 0 2rem;">
    {sorted.length} {sorted.length === 1 ? 'event' : 'events'} — chronological order. Activism,
    law reform, cultural moments, police actions, and memorials.
  </p>

  <div class="card-grid">
    {
      sorted.map(entry => {
        const d = entry.data;
        const slug = entry.id.replace(/\.md$/, '');
        return (
          <article class="card event-card">
            <div class="card-badges">
              <span class={eventTypeBadgeClass(d.event_type)}>{eventTypeLabel(d.event_type)}</span>
              {d.stub && <span class="badge badge-stub">Research needed</span>}
            </div>
            <a href={`/events/${slug}/`} class="card-name">
              {d.title}
            </a>
            <div class="card-meta">{d.date_display ?? d.date}</div>
            {d.related_cases.length > 0 && (
              <div class="card-meta">
                {d.related_cases.length} related {d.related_cases.length === 1 ? 'case' : 'cases'}
              </div>
            )}
          </article>
        );
      })
    }
  </div>
</Base>
