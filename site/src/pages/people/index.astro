---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const people = await getCollection('people');

// Sort by name within each group
const sorted = [...people].sort((a, b) => a.data.name.localeCompare(b.data.name));

// Group by role
const victims = sorted.filter(p => p.data.role === 'victim');
const communityActivists = sorted.filter(
  p => p.data.role === 'activist' || p.data.role === 'community' || p.data.role === 'journalist',
);
const legal = sorted.filter(
  p =>
    p.data.role === 'coroner' ||
    p.data.role === 'legal' ||
    p.data.role === 'expert-witness' ||
    p.data.role === 'pathologist' ||
    p.data.role === 'witness',
);

// Police: officers first, then commissioners (by institutional_role)
const allPolice = sorted.filter(
  p => p.data.role === 'police' || p.data.role === 'police-officer',
);
const policeCommissioners = allPolice.filter(p =>
  p.data.institutional_role?.toLowerCase().includes('commissioner'),
);
const policeOfficers = allPolice.filter(
  p => !p.data.institutional_role?.toLowerCase().includes('commissioner'),
);
const police = [...policeOfficers, ...policeCommissioners];

const political = sorted.filter(p => p.data.role === 'political');
const perpetrators = sorted.filter(p => p.data.role === 'perpetrator');
const other = sorted.filter(
  p =>
    p.data.role !== 'victim' &&
    p.data.role !== 'activist' &&
    p.data.role !== 'community' &&
    p.data.role !== 'journalist' &&
    p.data.role !== 'coroner' &&
    p.data.role !== 'legal' &&
    p.data.role !== 'expert-witness' &&
    p.data.role !== 'pathologist' &&
    p.data.role !== 'witness' &&
    p.data.role !== 'police' &&
    p.data.role !== 'police-officer' &&
    p.data.role !== 'political' &&
    p.data.role !== 'perpetrator',
);

function roleLabel(role: string): string {
  const labels: Record<string, string> = {
    victim: 'Victim',
    activist: 'Activist',
    witness: 'Witness',
    'expert-witness': 'Expert witness',
    pathologist: 'Pathologist',
    coroner: 'Coroner',
    perpetrator: 'Perpetrator',
    police: 'Police',
    'police-officer': 'Police officer',
    legal: 'Legal',
    political: 'Political',
    community: 'Community',
    journalist: 'Journalist',
    other: 'Other',
  };
  return labels[role] ?? role;
}

function roleBadgeClass(role: string): string {
  const classes: Record<string, string> = {
    victim: 'badge badge-homicide',
    activist: 'badge badge-beat',
    witness: 'badge badge-open',
    'expert-witness': 'badge badge-open',
    pathologist: 'badge badge-open',
    coroner: 'badge badge-scoi-b',
    perpetrator: 'badge badge-probable',
    police: 'badge badge-scoi-a',
    'police-officer': 'badge badge-scoi-a',
    legal: 'badge badge-scoi-b',
    political: 'badge badge-possible',
    community: 'badge badge-beat',
    journalist: 'badge badge-venue',
    other: 'badge badge-excluded',
  };
  return classes[role] ?? 'badge badge-excluded';
}

const groups = [
  { label: 'Victims', items: victims, desc: 'People whose deaths are examined in this project.' },
  {
    label: 'Community and activists',
    items: communityActivists,
    desc: 'Activists, community figures, and journalists who documented or fought for accountability.',
  },
  {
    label: 'Legal',
    items: legal,
    desc: 'Coroners, lawyers, judges, pathologists, and expert witnesses.',
  },
  { label: 'Police', items: police, desc: 'Officers and commissioners involved in these cases.' },
  { label: 'Political', items: political, desc: 'Politicians and officials.' },
  { label: 'Perpetrators', items: perpetrators, desc: 'Named perpetrators.' },
  { label: 'Other', items: other, desc: '' },
].filter(g => g.items.length > 0);
---

<Base
  title="People"
  description="Individuals in the Sackar Atlas research project — victims, activists, police, legal figures, and political actors."
>
  <h1>People</h1>
  <p class="text-muted text-ui" style="font-size:0.9rem; margin: 0.5rem 0 2rem;">
    {sorted.length} {sorted.length === 1 ? 'person' : 'people'} — victims, activists, police,
    legal, and political figures.
  </p>

  {
    groups.map(group => (
      <section style="margin-bottom: 2.5rem">
        <h2>
          {group.label} ({group.items.length})
        </h2>
        {group.desc && (
          <p class="text-muted text-ui" style="font-size:0.85rem; margin-bottom:1rem">
            {group.desc}
          </p>
        )}
        <div class="card-grid">
          {group.items.map(entry => {
            const d = entry.data;
            const slug = entry.id.replace(/\.md$/, '');
            return (
              <article class="card person-card">
                <div class="card-badges">
                  <span class={roleBadgeClass(d.role)}>{roleLabel(d.role)}</span>
                  {d.stub && <span class="badge badge-stub">Research needed</span>}
                </div>
                <a href={`/people/${slug}/`} class="card-name">
                  {d.name}
                </a>
                {d.institutional_role && (
                  <div class="card-meta">
                    {d.institutional_role}
                    {d.institution && `, ${d.institution}`}
                  </div>
                )}
                {d.birth_year && (
                  <div class="card-meta">
                    b. {d.birth_year}
                    {d.death_year && ` · d. ${d.death_year}`}
                  </div>
                )}
              </article>
            );
          })}
        </div>
      </section>
    ))
  }
</Base>
