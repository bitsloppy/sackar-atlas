---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';
import SectionCard from '../../components/SectionCard.astro';
import { ICONS, SECTION_TYPE_MAP } from '../../lib/icons';

export async function getStaticPaths() {
  const locations = await getCollection('locations');
  return locations.map(entry => ({
    params: { slug: entry.id.replace(/\.md$/, '') },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const d = entry.data;

// ── PAC jurisdiction map: build-time suburb boundary fetch ────────────────
// For police-jurisdiction locations with suburbs_covered[], we call the NSW
// Spatial Portal at build time and bake the GeoJSON into the static HTML.
// Data: Geoscape Administrative Boundaries © Geoscape Australia, CC-BY 4.0.
// No API key required. Gracefully falls back to no map if the API is down.

let pacSuburbGeoJson: object | null = null;

const isPAC = d.location_type === 'police-jurisdiction';
const hasSubs = isPAC && (d.suburbs_covered ?? []).length > 0;

if (hasSubs) {
  try {
    const names = (d.suburbs_covered ?? [])
      .map(s => s.toUpperCase())
      .map(s => `'${s}'`)
      .join(',');
    const url = new URL(
      'https://portal.spatial.nsw.gov.au/server/rest/services/Hosted/NSW_Boundary_Concordance/FeatureServer/3/query'
    );
    url.searchParams.set('where', `suburbname IN (${names})`);
    url.searchParams.set('outFields', 'suburbname,postcode');
    url.searchParams.set('f', 'geojson');

    const res = await fetch(url.toString());
    if (!res.ok) throw new Error(`HTTP ${res.status}`);
    pacSuburbGeoJson = await res.json();
  } catch (e) {
    console.warn(`[${entry.id}] PAC suburb boundary fetch failed:`, e);
  }
}

// Shield icon for PAC station pins — from central registry
const shieldIcon = ICONS.shieldHalved;

const pacGeoJsonStr   = JSON.stringify(pacSuburbGeoJson);
const shieldIconStr   = JSON.stringify(shieldIcon);
const stationsStr     = JSON.stringify(
  (d.stations ?? []).filter(s => s.lat != null && s.lng != null)
);

// Section accordion config — serialised for client-side JS enhancement
// Builds a map of { [headingText]: { type, open, iconSvg, colour } } so the
// client script can wrap markdown h2s in <details> cards with the right icon.
const sectionConfig: Record<string, { type: string; open: boolean; iconSvg: string; colour: string }> = {};
for (const s of (d.sections ?? [])) {
  const meta = SECTION_TYPE_MAP[s.type] ?? SECTION_TYPE_MAP.general;
  const ic   = ICONS[meta.icon as keyof typeof ICONS];
  const svgH = 13;
  const svgW = Math.round(svgH * (ic.w / ic.h));
  const svg  = `<svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 ${ic.w} ${ic.h}" width="${svgW}" height="${svgH}" fill="${meta.colour}"><path d="${ic.path}"/></svg>`;
  sectionConfig[s.heading] = { type: s.type, open: s.open, iconSvg: svg, colour: meta.colour };
}
const sectionConfigStr = JSON.stringify(sectionConfig);

// Cross-reference related content
const allCases = await getCollection('cases', ({ data }) => data.published === true);
const allEvents = await getCollection('events');
const allPeople = await getCollection('people');
const allLocations = await getCollection('locations');

const relatedCases = (d.related_cases ?? [])
  .map(id => allCases.find(c => c.id.replace(/\.md$/, '') === id))
  .filter((x): x is NonNullable<typeof x> => x != null);

const relatedEvents = (d.related_events ?? [])
  .map(id => allEvents.find(e => e.id.replace(/\.md$/, '') === id))
  .filter((x): x is NonNullable<typeof x> => x != null);

const relatedPeople = (d.related_people ?? [])
  .map(id => allPeople.find(p => p.id.replace(/\.md$/, '') === id))
  .filter((x): x is NonNullable<typeof x> => x != null);

const relatedLocations = (d.related_locations ?? [])
  .map(id => allLocations.find(l => l.id.replace(/\.md$/, '') === id))
  .filter((x): x is NonNullable<typeof x> => x != null);

function roleLabel(role: string): string {
  const labels: Record<string, string> = {
    beat: 'Beat',
    'nightlife-venue': 'Nightlife venue',
    'march-route': 'March route',
    'crime-scene': 'Crime scene',
    'last-seen': 'Last seen',
    memorial: 'Memorial',
    institution: 'Institutional',
    institutional: 'Institutional',
    'community-hub': 'Community hub',
    'burial-site': 'Burial site',
  };
  return labels[role] ?? role;
}

function roleBadgeClass(role: string): string {
  const classes: Record<string, string> = {
    beat: 'badge badge-beat',
    'nightlife-venue': 'badge badge-venue',
    'crime-scene': 'badge badge-homicide',
    memorial: 'badge badge-possible',
    'last-seen': 'badge badge-probable',
  };
  return classes[role] ?? 'badge badge-open';
}

function statusLabel(status: string | undefined): string {
  const labels: Record<string, string> = {
    'confirmed-homicide': 'Confirmed homicide',
    probable: 'Probable hate crime',
    possible: 'Possible hate crime',
    open: 'Open finding',
    undetermined: 'Undetermined',
    excluded: 'Excluded',
    missing: 'Missing person',
  };
  return labels[status ?? ''] ?? status ?? '—';
}

function statusBadgeClass(status: string | undefined): string {
  const classes: Record<string, string> = {
    'confirmed-homicide': 'badge badge-homicide',
    probable: 'badge badge-probable',
    possible: 'badge badge-possible',
    open: 'badge badge-open',
    undetermined: 'badge badge-open',
    excluded: 'badge badge-excluded',
    missing: 'badge badge-open',
  };
  return classes[status ?? ''] ?? 'badge badge-open';
}

function countryDeterminationLabel(s: string | undefined): string {
  const labels: Record<string, string> = {
    'community-confirmed': 'Confirmed by community',
    'local-land-council': 'Via local land council',
    'language-centre': 'Via language centre',
    'aiatsis-map': 'AIATSIS Map',
    'researcher-assessed': 'Researcher assessed (provisional)',
    'not-assessed': 'Not yet assessed',
  };
  return labels[s ?? ''] ?? s ?? '—';
}
---

<Base title={d.name} description={`Location: ${d.name}. ${d.suburb ?? ''} — Sackar Atlas.`}>
  <!-- ══ SECTION: Stub warning ═══════════════════════════════════════════════ -->
  <!-- Conditional: only shown when stub: true on the location.               -->
  {
    d.stub && (
      <div class="stub-warning">
        <strong>Research stub:</strong> This location record is a placeholder. Key details may be
        incomplete or unverified. Contributions welcome.
      </div>
    )
  }

  <!-- ══ SECTION: Header ════════════════════════════════════════════════════ -->
  <!-- Name, type badge, suburb, region, First Nations country.               -->
  <div class="detail-header">
    <h1>{d.name}</h1>

    {
      d.also_known_as.length > 0 && (
        <p class="text-muted text-ui" style="font-size:0.85rem; margin-bottom:0.5rem">
          Also known as: {d.also_known_as.join(', ')}
        </p>
      )
    }

    <div class="detail-meta">
      {d.suburb && (
        <span>
          📍 <a
            href={`/locations/?suburb=${encodeURIComponent(d.suburb.toLowerCase())}`}
            class="meta-link"
          >{d.suburb}</a>
        </span>
      )}
      {d.location_region && (
        <a
          href={`/locations/region/${d.location_region}/`}
          class="meta-link"
        >{d.location_region.replace(/-/g, ' ')}</a>
      )}
      {d.active_from && (
        <span>
          {d.active_from}
          {d.active_to ? `–${d.active_to}` : d.still_exists === false ? ' (closed)' : '–present'}
        </span>
      )}
    </div>

    <div class="detail-badges">
      <span class="badge badge-excluded">{d.location_type.replace(/-/g, ' ')}</span>
      {d.location_roles?.map(role => (
        <span class={roleBadgeClass(role)}>{roleLabel(role)}</span>
      ))}
      {d.stub && <span class="badge badge-stub">Research needed</span>}
    </div>
  </div>

  <!-- ══ SECTION: Key facts grid ════════════════════════════════════════════ -->
  <!-- Type · Suburb · Region · Country · PAC jurisdiction · Active dates     -->
  <div class="fact-grid">
    {
      d.first_nations_country && (
        <div class="fact">
          <span class="fact-label">Country</span>
          <span class="fact-value">
            {d.first_nations_country}
            {d.first_nations_country_additional && ` / ${d.first_nations_country_additional}`}
            {d.country_determination && (
              <span class="text-muted" style="font-size:0.8rem">
                <br />
                {countryDeterminationLabel(d.country_determination)}
              </span>
            )}
          </span>
        </div>
      )
    }

    {
      d.still_exists !== undefined && (
        <div class="fact">
          <span class="fact-label">Still exists</span>
          <span class="fact-value">{d.still_exists ? 'Yes' : 'No'}</span>
        </div>
      )
    }

    {
      d.current_name && (
        <div class="fact">
          <span class="fact-label">Now known as</span>
          <span class="fact-value">{d.current_name}</span>
        </div>
      )
    }

    {
      d.street_address && (
        <div class="fact">
          <span class="fact-label">Address</span>
          <span class="fact-value">{d.street_address}</span>
        </div>
      )
    }

    {
      d.phone && (
        <div class="fact">
          <span class="fact-label">Phone</span>
          <span class="fact-value">{d.phone}</span>
        </div>
      )
    }
  </div>

  <!-- ══ SECTION: Acknowledgement of Country ═══════════════════════════════ -->
  <!-- Always shown. Country name pulled from data.                           -->
  {
    d.acknowledgement && (
      <div class="finding-box" style="margin-bottom:2rem; border-color:#2a3a2a">
        <div class="label">Acknowledgement of Country</div>
        <div class="value" style="font-size:0.92rem">{d.acknowledgement}</div>
      </div>
    )
  }

  <!-- ══ SECTION: PAC jurisdiction map ═════════════════════════════════════ -->
  <!-- Conditional: only for location_type=police-jurisdiction with           -->
  <!-- suburbs_covered[] set. Fetches NSW Spatial Portal boundaries at build. -->
  {isPAC && hasSubs && (
    <section class="pac-map-section" aria-label="Jurisdiction map">
      <p class="section-heading">Jurisdiction map</p>

      {pacSuburbGeoJson ? (
        <>
          <div
            id="pac-map"
            role="application"
            aria-label={`Map showing suburbs covered by ${d.name}`}
            tabindex="0"
            style="width:100%; height:360px; border-radius:6px; border:1px solid var(--border); overflow:hidden;"
          ></div>
          <p class="text-muted text-ui" style="font-size:0.75rem; margin-top:0.4rem">
            Suburb boundaries: Geoscape Administrative Boundaries
            &copy; <a href="https://geoscape.com.au/legal/data-copyright-and-disclaimer/">Geoscape Australia</a>,
            licensed under <a href="https://creativecommons.org/licenses/by/4.0/">CC-BY 4.0</a>.
            Map tiles: <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> / <a href="https://carto.com/attributions">CARTO</a>.
          </p>
          <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
          <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" is:inline></script>
          <script define:vars={{ pacGeoJsonStr, shieldIconStr, stationsStr }}>
            const geoJson   = JSON.parse(pacGeoJsonStr);
            const shield    = JSON.parse(shieldIconStr);
            const stations  = JSON.parse(stationsStr);

            const map = L.map('pac-map', { zoomControl: true, attributionControl: false });

            L.tileLayer(
              'https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png',
              { subdomains: 'abcd', maxZoom: 19 }
            ).addTo(map);

            // Suburb polygon layer
            const suburbLayer = L.geoJSON(geoJson, {
              style: {
                color:       '#4a7faa',
                weight:      2,
                opacity:     0.8,
                fillColor:   '#4a7faa',
                fillOpacity: 0.12,
              },
              onEachFeature(feature, layer) {
                const name = feature.properties?.suburbname ?? '';
                layer.bindTooltip(
                  `<span style="font-family:system-ui;font-size:0.82rem;color:#dcdcf0">${name}</span>`,
                  { sticky: true, className: 'pac-tooltip' }
                );
              },
            }).addTo(map);

            // Fit map to suburb boundaries
            map.fitBounds(suburbLayer.getBounds(), { padding: [20, 20] });

            // Station pins
            const svgH = 13;
            const svgW = Math.round(svgH * (shield.w / shield.h));
            const iconSvg = `<svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 ${shield.w} ${shield.h}" width="${svgW}" height="${svgH}" fill="white"><path d="${shield.path}"/></svg>`;

            function stationPin(isHQ) {
              const size = isHQ ? 26 : 22;
              const tail = Math.round(size / 3.5);
              const tailH = Math.round(tail * 1.4);
              const colour = isHQ ? '#4a7faa' : '#2a5a8a';
              return L.divIcon({
                html: `<div style="display:flex;flex-direction:column;align-items:center;width:${size}px">
                  <div style="width:${size}px;height:${size}px;border-radius:50%;background:${colour};border:2px solid rgba(255,255,255,0.5);box-shadow:0 2px 8px rgba(0,0,0,0.6);display:flex;align-items:center;justify-content:center">${iconSvg}</div>
                  <div style="width:0;height:0;border-left:${tail}px solid transparent;border-right:${tail}px solid transparent;border-top:${tailH}px solid ${colour};margin-top:-1px"></div>
                </div>`,
                className: '',
                iconSize: [size, size + tailH],
                iconAnchor: [size / 2, size + tailH],
                popupAnchor: [0, -(size + tailH + 4)],
              });
            }

            stations.forEach(st => {
              L.marker([st.lat, st.lng], { icon: stationPin(st.is_hq) })
                .bindPopup(`
                  <div style="font-family:system-ui;min-width:160px">
                    <strong>${st.name}</strong><br>
                    <span style="font-size:0.82rem;color:#aaa">${st.address ?? ''}</span><br>
                    ${st.phone ? `<span style="font-size:0.82rem;color:#7eb8f8">${st.phone}</span><br>` : ''}
                    ${st.hours ? `<span style="font-size:0.78rem;color:#7878a0">${st.hours}</span>` : ''}
                  </div>`, { maxWidth: 240 }
                )
                .addTo(map);
            });
          </script>
        </>
      ) : (
        <p class="text-muted text-ui" style="font-size:0.85rem; font-style:italic">
          Jurisdiction map unavailable — suburb boundary data could not be loaded at build time.
        </p>
      )}
    </section>
  )}

  <!-- ══ SECTION: Narrative body ════════════════════════════════════════════ -->
  <!-- Markdown prose from the data file. h2 headings are progressively       -->
  <!-- wrapped in SectionCard accordions by the inline script below.          -->
  <!-- Each h2 must match a sections[] entry in the data file (type, open).   -->
  <div class="narrative" id="loc-narrative">
    <Content />
  </div>

  {(d.sections ?? []).length > 0 && (
    <script define:vars={{ sectionConfigStr }}>
      (function () {
        const cfg     = JSON.parse(sectionConfigStr);
        const narr    = document.getElementById('loc-narrative');
        if (!narr) return;
        const h2s = Array.from(narr.querySelectorAll('h2'));
        if (!h2s.length) return;

        h2s.forEach(h2 => {
          const heading  = h2.textContent?.trim() ?? '';
          const meta     = cfg[heading] ?? { open: true, iconSvg: '', colour: 'var(--muted)' };

          // Collect siblings until next h2 or end of narrative
          const siblings = [];
          let node = h2.nextSibling;
          while (node && !(node.nodeType === 1 && node.tagName === 'H2')) {
            siblings.push(node);
            node = node.nextSibling;
          }

          // Build <details> card
          const details  = document.createElement('details');
          if (meta.open) details.open = true;
          details.className = 'section-card';

          const summary  = document.createElement('summary');
          summary.className = 'section-card-header';
          summary.innerHTML = [
            meta.iconSvg
              ? `<span class="section-icon" aria-hidden="true" style="color:${meta.colour}">${meta.iconSvg}</span>`
              : '',
            `<span class="section-card-title">${heading}</span>`,
            `<span class="section-chevron" aria-hidden="true"></span>`,
          ].join('');

          const body = document.createElement('div');
          body.className = 'section-card-body';
          siblings.forEach(s => body.appendChild(s.cloneNode(true)));

          details.appendChild(summary);
          details.appendChild(body);

          // Replace h2 + siblings with the new details card
          h2.parentNode.insertBefore(details, h2);
          h2.remove();
          siblings.forEach(s => { if (s.parentNode) s.parentNode.removeChild(s); });
        });
      })();
    </script>
  )}

  <!-- ══ SECTION: Physical markers ══════════════════════════════════════════ -->
  <!-- Conditional: only shown when physical_markers[] is not empty.          -->
  {
    d.physical_markers.length > 0 && (
      <SectionCard type="memorial" heading="Physical markers" open={false}>
        {d.physical_markers.map(marker => (
          <div class="finding-box" style="margin-bottom:0.75rem">
            <div class="label">
              {marker.type.replace(/-/g, ' ')}
              {marker.installed && ` · ${marker.installed}`}
            </div>
            {marker.name && <div class="value">{marker.name}</div>}
            {marker.description && (
              <div class="text-muted text-ui" style="font-size:0.85rem; margin-top:0.3rem">
                {marker.description}
              </div>
            )}
            {marker.managed_by && (
              <div class="text-muted text-ui" style="font-size:0.82rem">
                Managed by: {marker.managed_by}
              </div>
            )}
            {marker.type === 'proposed' && (
              <div
                class="text-muted text-ui"
                style="font-size:0.8rem; margin-top:0.3rem; font-style:italic"
              >
                Called for by the Sackar Inquiry (Chapter 16) — not yet installed.
              </div>
            )}
          </div>
        ))}
      </SectionCard>
    )
  }

  <hr />

  <!-- ══ SECTION: Related cases ════════════════════════════════════════════ -->
  <!-- Conditional. Shows count in heading.                                   -->
  {
    relatedCases.length > 0 && (
      <SectionCard type="cases" heading={`Related cases (${relatedCases.length})`} open={true}>
        <div class="card-grid">
          {relatedCases.map(c => {
            const slug = c.id.replace(/\.md$/, '');
            const siteStatus = c.data.manner_findings?.site_status;
            return (
              <article class="card">
                <div class="card-badges">
                  {c.data.scoi_category && (
                    <span class={`badge badge-scoi-${c.data.scoi_category.toLowerCase()}`}>
                      SCOI Cat. {c.data.scoi_category}
                    </span>
                  )}
                  {siteStatus && (
                    <span class={statusBadgeClass(siteStatus)}>{statusLabel(siteStatus)}</span>
                  )}
                </div>
                <a href={`/cases/${slug}/`} class="card-name">
                  {c.data.name}
                </a>
                <div class="card-meta">
                  {c.data.date_of_death_display ?? c.data.date_of_death ?? 'Date unknown'}
                </div>
              </article>
            );
          })}
        </div>
      </SectionCard>
    )
  }

  <!-- ══ SECTION: Related events ═══════════════════════════════════════════ -->
  <!-- Conditional.                                                           -->
  {
    relatedEvents.length > 0 && (
      <SectionCard type="events" heading="Related events" open={false}>
        <div class="related-chips">
          {relatedEvents.map(e => {
            const slug = e.id.replace(/\.md$/, '');
            return (
              <a href={`/events/${slug}/`} class="related-chip">
                {e.data.title}
                {(e.data.date_display ?? e.data.date) && (
                  <span class="chip-meta">
                    {' '}
                    · {e.data.date_display ?? e.data.date}
                  </span>
                )}
              </a>
            );
          })}
        </div>
      </SectionCard>
    )
  }

  <!-- ══ SECTION: Related people ═══════════════════════════════════════════ -->
  <!-- Conditional.                                                           -->
  {
    relatedPeople.length > 0 && (
      <SectionCard type="people" heading="Related people" open={false}>
        <div class="related-chips">
          {relatedPeople.map(p => {
            const slug = p.id.replace(/\.md$/, '');
            return (
              <a href={`/people/${slug}/`} class="related-chip">
                {p.data.name}
                <span class="chip-meta"> · {p.data.role}</span>
              </a>
            );
          })}
        </div>
      </SectionCard>
    )
  }

  <!-- ══ SECTION: Related locations ════════════════════════════════════════ -->
  <!-- Conditional.                                                           -->
  {
    relatedLocations.length > 0 && (
      <SectionCard type="locations" heading="Related locations" open={false}>
        <div class="related-chips">
          {relatedLocations.map(l => {
            const slug = l.id.replace(/\.md$/, '');
            return (
              <a href={`/locations/${slug}/`} class="related-chip">
                {l.data.name}
                {l.data.suburb && <span class="chip-meta"> · {l.data.suburb}</span>}
              </a>
            );
          })}
        </div>
      </SectionCard>
    )
  }

  <!-- ══ SECTION: Sources ══════════════════════════════════════════════════ -->
  <!-- Always shown (may be sparse for stubs).                                -->
  <SectionCard type="sources" heading="Sources" open={false}>

    {
      d.sources.scoi && (
        <div class="finding-box">
          <div class="label">
            SCOI Report — Volume {d.sources.scoi.volume}
            {d.sources.scoi.chapter && `, Chapter ${d.sources.scoi.chapter}`}
            {d.sources.scoi.paragraph && `, para ${d.sources.scoi.paragraph}`}
            {d.sources.scoi.page_start &&
              `, pp. ${d.sources.scoi.page_start}${d.sources.scoi.page_end ? `–${d.sources.scoi.page_end}` : ''}`}
          </div>
          <div class="value text-ui" style="font-size:0.85rem">
            NSW Special Commission of Inquiry into LGBTIQ Hate Crimes (Sackar J) (2023)
            <em>Report of the Special Commission of Inquiry</em>, vol. {d.sources.scoi.volume},
            NSW Government, Sydney.
          </div>
        </div>
      )
    }

    {
      d.sources.press.length > 0 && (
        <div style="margin-top:1rem">
          <h4 style="margin-bottom:0.5rem">Press sources</h4>
          <ul
            class="text-ui"
            style="font-size:0.85rem; list-style:none; display:flex; flex-direction:column; gap:0.5rem"
          >
            {d.sources.press.map(p => (
              <li>
                {p.author && <>{p.author} </>}
                {p.date && <>({p.date}) </>}
                '{p.title}',<em> {p.publication}</em>
                {p.page && <>, p. {p.page}</>}
                {p.trove_url && (
                  <>
                    {' '}
                    · <a href={p.trove_url}>Trove</a>
                  </>
                )}
                {!p.trove_url && p.url && (
                  <>
                    {' '}
                    · <a href={p.url}>{p.url}</a>
                  </>
                )}
              </li>
            ))}
          </ul>
        </div>
      )
    }

    {
      d.sources.geographic.length > 0 && (
        <div style="margin-top:1rem">
          <h4 style="margin-bottom:0.5rem">Geographic sources</h4>
          <ul
            class="text-ui"
            style="font-size:0.85rem; list-style:none; display:flex; flex-direction:column; gap:0.5rem"
          >
            {d.sources.geographic.map(g => (
              <li>
                {g.service}
                {g.reference && <>, ref. {g.reference}</>}
                {g.url && (
                  <>
                    {' '}
                    · <a href={g.url}>{g.url}</a>
                  </>
                )}
              </li>
            ))}
          </ul>
        </div>
      )
    }

    {
      d.sources.archives.length > 0 && (
        <div style="margin-top:1rem">
          <h4 style="margin-bottom:0.5rem">Archival records</h4>
          <ul
            class="text-ui"
            style="font-size:0.85rem; list-style:none; display:flex; flex-direction:column; gap:0.5rem"
          >
            {d.sources.archives.map(a => (
              <li>
                {a.institution.replace(/-/g, ' ')}
                {a.collection && <>, {a.collection}</>}
                {a.item_id && <>, item {a.item_id}</>}
                {a.description && <> — {a.description}</>}
              </li>
            ))}
          </ul>
        </div>
      )
    }
  </SectionCard>

  <!-- ══ SECTION: Back link ════════════════════════════════════════════════ -->
  <div style="margin-top:3rem; padding-top:1rem; border-top:1px solid var(--border)">
    <a href="/locations/" class="text-ui" style="font-size:0.88rem">← All locations</a>
  </div>
</Base>
