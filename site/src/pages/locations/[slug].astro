---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const locations = await getCollection('locations');
  return locations.map(entry => ({
    params: { slug: entry.id.replace(/\.md$/, '') },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const d = entry.data;

// Cross-reference related content
const allCases = await getCollection('cases', ({ data }) => data.published === true);
const allEvents = await getCollection('events');
const allPeople = await getCollection('people');
const allLocations = await getCollection('locations');

const relatedCases = (d.related_cases ?? [])
  .map(id => allCases.find(c => c.id.replace(/\.md$/, '') === id))
  .filter((x): x is NonNullable<typeof x> => x != null);

const relatedEvents = (d.related_events ?? [])
  .map(id => allEvents.find(e => e.id.replace(/\.md$/, '') === id))
  .filter((x): x is NonNullable<typeof x> => x != null);

const relatedPeople = (d.related_people ?? [])
  .map(id => allPeople.find(p => p.id.replace(/\.md$/, '') === id))
  .filter((x): x is NonNullable<typeof x> => x != null);

const relatedLocations = (d.related_locations ?? [])
  .map(id => allLocations.find(l => l.id.replace(/\.md$/, '') === id))
  .filter((x): x is NonNullable<typeof x> => x != null);

function roleLabel(role: string): string {
  const labels: Record<string, string> = {
    beat: 'Beat',
    'nightlife-venue': 'Nightlife venue',
    'march-route': 'March route',
    'crime-scene': 'Crime scene',
    'last-seen': 'Last seen',
    memorial: 'Memorial',
    institution: 'Institutional',
    institutional: 'Institutional',
    'community-hub': 'Community hub',
    'burial-site': 'Burial site',
  };
  return labels[role] ?? role;
}

function roleBadgeClass(role: string): string {
  const classes: Record<string, string> = {
    beat: 'badge badge-beat',
    'nightlife-venue': 'badge badge-venue',
    'crime-scene': 'badge badge-homicide',
    memorial: 'badge badge-possible',
    'last-seen': 'badge badge-probable',
  };
  return classes[role] ?? 'badge badge-open';
}

function statusLabel(status: string | undefined): string {
  const labels: Record<string, string> = {
    'confirmed-homicide': 'Confirmed homicide',
    probable: 'Probable hate crime',
    possible: 'Possible hate crime',
    open: 'Open finding',
    undetermined: 'Undetermined',
    excluded: 'Excluded',
    missing: 'Missing person',
  };
  return labels[status ?? ''] ?? status ?? '—';
}

function statusBadgeClass(status: string | undefined): string {
  const classes: Record<string, string> = {
    'confirmed-homicide': 'badge badge-homicide',
    probable: 'badge badge-probable',
    possible: 'badge badge-possible',
    open: 'badge badge-open',
    undetermined: 'badge badge-open',
    excluded: 'badge badge-excluded',
    missing: 'badge badge-open',
  };
  return classes[status ?? ''] ?? 'badge badge-open';
}

function countryDeterminationLabel(s: string | undefined): string {
  const labels: Record<string, string> = {
    'community-confirmed': 'Confirmed by community',
    'local-land-council': 'Via local land council',
    'language-centre': 'Via language centre',
    'aiatsis-map': 'AIATSIS Map',
    'researcher-assessed': 'Researcher assessed (provisional)',
    'not-assessed': 'Not yet assessed',
  };
  return labels[s ?? ''] ?? s ?? '—';
}
---

<Base title={d.name} description={`Location: ${d.name}. ${d.suburb ?? ''} — Queer Heritage Sydney.`}>
  <!-- Stub notice -->
  {
    d.stub && (
      <div class="content-warning" style="background:#1a1610; border-color:#5a4510; color:#c0a060;">
        <strong>Research stub:</strong> This location record is a placeholder. Key details may be
        incomplete or unverified. Contributions welcome.
      </div>
    )
  }

  <!-- Header -->
  <div class="detail-header">
    <h1>{d.name}</h1>

    {
      d.also_known_as.length > 0 && (
        <p class="text-muted text-ui" style="font-size:0.85rem; margin-bottom:0.5rem">
          Also known as: {d.also_known_as.join(', ')}
        </p>
      )
    }

    <div class="detail-meta">
      {d.suburb && (
        <span>
          📍 <a
            href={`/locations/?suburb=${encodeURIComponent(d.suburb.toLowerCase())}`}
            class="meta-link"
          >{d.suburb}</a>
        </span>
      )}
      {d.location_region && (
        <a
          href={`/locations/?region=${d.location_region}`}
          class="meta-link"
        >{d.location_region.replace(/-/g, ' ')}</a>
      )}
      {d.active_from && (
        <span>
          {d.active_from}
          {d.active_to ? `–${d.active_to}` : d.still_exists === false ? ' (closed)' : '–present'}
        </span>
      )}
    </div>

    <div class="detail-badges">
      <span class="badge badge-excluded">{d.location_type.replace(/-/g, ' ')}</span>
      {d.location_roles?.map(role => (
        <span class={roleBadgeClass(role)}>{roleLabel(role)}</span>
      ))}
      {d.stub && <span class="badge badge-stub">Research needed</span>}
    </div>
  </div>

  <!-- Key facts -->
  <div class="fact-grid">
    {
      d.first_nations_country && (
        <div class="fact">
          <span class="fact-label">Country</span>
          <span class="fact-value">
            {d.first_nations_country}
            {d.first_nations_country_additional && ` / ${d.first_nations_country_additional}`}
            {d.country_determination && (
              <span class="text-muted" style="font-size:0.8rem">
                <br />
                {countryDeterminationLabel(d.country_determination)}
              </span>
            )}
          </span>
        </div>
      )
    }

    {
      d.still_exists !== undefined && (
        <div class="fact">
          <span class="fact-label">Still exists</span>
          <span class="fact-value">{d.still_exists ? 'Yes' : 'No'}</span>
        </div>
      )
    }

    {
      d.current_name && (
        <div class="fact">
          <span class="fact-label">Now known as</span>
          <span class="fact-value">{d.current_name}</span>
        </div>
      )
    }

    {
      d.street_address && (
        <div class="fact">
          <span class="fact-label">Address</span>
          <span class="fact-value">{d.street_address}</span>
        </div>
      )
    }

    {
      d.phone && (
        <div class="fact">
          <span class="fact-label">Phone</span>
          <span class="fact-value">{d.phone}</span>
        </div>
      )
    }
  </div>

  <!-- Acknowledgement of Country -->
  {
    d.acknowledgement && (
      <div class="finding-box" style="margin-bottom:2rem; border-color:#2a3a2a">
        <div class="label">Acknowledgement of Country</div>
        <div class="value" style="font-size:0.92rem">{d.acknowledgement}</div>
      </div>
    )
  }

  <!-- Narrative body -->
  <div class="narrative">
    <Content />
  </div>

  <!-- Physical markers -->
  {
    d.physical_markers.length > 0 && (
      <section style="margin:2rem 0">
        <p class="section-heading">Physical markers</p>
        {d.physical_markers.map(marker => (
          <div class="finding-box" style="margin-bottom:0.75rem">
            <div class="label">
              {marker.type.replace(/-/g, ' ')}
              {marker.installed && ` · ${marker.installed}`}
            </div>
            {marker.name && <div class="value">{marker.name}</div>}
            {marker.description && (
              <div class="text-muted text-ui" style="font-size:0.85rem; margin-top:0.3rem">
                {marker.description}
              </div>
            )}
            {marker.managed_by && (
              <div class="text-muted text-ui" style="font-size:0.82rem">
                Managed by: {marker.managed_by}
              </div>
            )}
            {marker.type === 'proposed' && (
              <div
                class="text-muted text-ui"
                style="font-size:0.8rem; margin-top:0.3rem; font-style:italic"
              >
                Called for by the Sackar Inquiry (Chapter 16) — not yet installed.
              </div>
            )}
          </div>
        ))}
      </section>
    )
  }

  <hr />

  <!-- Related cases -->
  {
    relatedCases.length > 0 && (
      <section style="margin:2rem 0">
        <p class="section-heading">Related cases ({relatedCases.length})</p>
        <div class="card-grid">
          {relatedCases.map(c => {
            const slug = c.id.replace(/\.md$/, '');
            const siteStatus = c.data.manner_findings?.site_status;
            return (
              <article class="card">
                <div class="card-badges">
                  {c.data.scoi_category && (
                    <span class={`badge badge-scoi-${c.data.scoi_category.toLowerCase()}`}>
                      SCOI Cat. {c.data.scoi_category}
                    </span>
                  )}
                  {siteStatus && (
                    <span class={statusBadgeClass(siteStatus)}>{statusLabel(siteStatus)}</span>
                  )}
                </div>
                <a href={`/cases/${slug}/`} class="card-name">
                  {c.data.name}
                </a>
                <div class="card-meta">
                  {c.data.date_of_death_display ?? c.data.date_of_death ?? 'Date unknown'}
                </div>
              </article>
            );
          })}
        </div>
      </section>
    )
  }

  <!-- Related events -->
  {
    relatedEvents.length > 0 && (
      <section style="margin:2rem 0">
        <p class="section-heading">Related events</p>
        <div class="related-chips">
          {relatedEvents.map(e => {
            const slug = e.id.replace(/\.md$/, '');
            return (
              <a href={`/events/${slug}/`} class="related-chip">
                {e.data.title}
                {(e.data.date_display ?? e.data.date) && (
                  <span class="chip-meta">
                    {' '}
                    · {e.data.date_display ?? e.data.date}
                  </span>
                )}
              </a>
            );
          })}
        </div>
      </section>
    )
  }

  <!-- Related people -->
  {
    relatedPeople.length > 0 && (
      <section style="margin:2rem 0">
        <p class="section-heading">Related people</p>
        <div class="related-chips">
          {relatedPeople.map(p => {
            const slug = p.id.replace(/\.md$/, '');
            return (
              <a href={`/people/${slug}/`} class="related-chip">
                {p.data.name}
                <span class="chip-meta"> · {p.data.role}</span>
              </a>
            );
          })}
        </div>
      </section>
    )
  }

  <!-- Related locations -->
  {
    relatedLocations.length > 0 && (
      <section style="margin:2rem 0">
        <p class="section-heading">Related locations</p>
        <div class="related-chips">
          {relatedLocations.map(l => {
            const slug = l.id.replace(/\.md$/, '');
            return (
              <a href={`/locations/${slug}/`} class="related-chip">
                {l.data.name}
                {l.data.suburb && <span class="chip-meta"> · {l.data.suburb}</span>}
              </a>
            );
          })}
        </div>
      </section>
    )
  }

  <!-- Sources -->
  <section style="margin:2rem 0">
    <p class="section-heading">Sources</p>

    {
      d.sources.scoi && (
        <div class="finding-box">
          <div class="label">
            SCOI Report — Volume {d.sources.scoi.volume}
            {d.sources.scoi.chapter && `, Chapter ${d.sources.scoi.chapter}`}
            {d.sources.scoi.paragraph && `, para ${d.sources.scoi.paragraph}`}
            {d.sources.scoi.page_start &&
              `, pp. ${d.sources.scoi.page_start}${d.sources.scoi.page_end ? `–${d.sources.scoi.page_end}` : ''}`}
          </div>
          <div class="value text-ui" style="font-size:0.85rem">
            NSW Special Commission of Inquiry into LGBTIQ Hate Crimes (Sackar J) (2023)
            <em>Report of the Special Commission of Inquiry</em>, vol. {d.sources.scoi.volume},
            NSW Government, Sydney.
          </div>
        </div>
      )
    }

    {
      d.sources.press.length > 0 && (
        <div style="margin-top:1rem">
          <h4 style="margin-bottom:0.5rem">Press sources</h4>
          <ul
            class="text-ui"
            style="font-size:0.85rem; list-style:none; display:flex; flex-direction:column; gap:0.5rem"
          >
            {d.sources.press.map(p => (
              <li>
                {p.author && <>{p.author} </>}
                {p.date && <>({p.date}) </>}
                '{p.title}',<em> {p.publication}</em>
                {p.page && <>, p. {p.page}</>}
                {p.trove_url && (
                  <>
                    {' '}
                    · <a href={p.trove_url}>Trove</a>
                  </>
                )}
                {!p.trove_url && p.url && (
                  <>
                    {' '}
                    · <a href={p.url}>{p.url}</a>
                  </>
                )}
              </li>
            ))}
          </ul>
        </div>
      )
    }

    {
      d.sources.geographic.length > 0 && (
        <div style="margin-top:1rem">
          <h4 style="margin-bottom:0.5rem">Geographic sources</h4>
          <ul
            class="text-ui"
            style="font-size:0.85rem; list-style:none; display:flex; flex-direction:column; gap:0.5rem"
          >
            {d.sources.geographic.map(g => (
              <li>
                {g.service}
                {g.reference && <>, ref. {g.reference}</>}
                {g.url && (
                  <>
                    {' '}
                    · <a href={g.url}>{g.url}</a>
                  </>
                )}
              </li>
            ))}
          </ul>
        </div>
      )
    }

    {
      d.sources.archives.length > 0 && (
        <div style="margin-top:1rem">
          <h4 style="margin-bottom:0.5rem">Archival records</h4>
          <ul
            class="text-ui"
            style="font-size:0.85rem; list-style:none; display:flex; flex-direction:column; gap:0.5rem"
          >
            {d.sources.archives.map(a => (
              <li>
                {a.institution.replace(/-/g, ' ')}
                {a.collection && <>, {a.collection}</>}
                {a.item_id && <>, item {a.item_id}</>}
                {a.description && <> — {a.description}</>}
              </li>
            ))}
          </ul>
        </div>
      )
    }
  </section>

  <!-- Back link -->
  <div style="margin-top:3rem; padding-top:1rem; border-top:1px solid var(--border)">
    <a href="/locations/" class="text-ui" style="font-size:0.88rem">← All locations</a>
  </div>
</Base>
